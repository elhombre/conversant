# Runtime scope: apps/frontend (Next.js server route handlers)
# Required: OpenAI API key used by /api/stt, /api/chat, /api/tts
# Keep identical with packages/backend-core/.env(.local) when both are used in one runtime.
OPENAI_API_KEY=sk-your-key-here

# Required (for DB-backed features): PostgreSQL connection string used by Prisma
# Keep identical with packages/backend-data/.env(.local).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conversant?schema=public

# Optional: custom OpenAI-compatible base URL (defaults to OpenAI when empty)
# Keep identical with packages/backend-core/.env(.local) when both are used in one runtime.
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: STT model override
# Keep identical with packages/backend-core/.env(.local) when both are used in one runtime.
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Optional: language detection model for strict multi-language STT filter
# Keep identical with packages/backend-core/.env(.local) when both are used in one runtime.
OPENAI_STT_LANGUAGE_DETECT_MODEL=whisper-1

# Optional: chat model override
# Keep identical with packages/backend-core/.env(.local) when both are used in one runtime.
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: TTS model override
# Keep identical with packages/backend-core/.env(.local) when both are used in one runtime.
OPENAI_TTS_MODEL=tts-1

# Demo auth (planned): required secret for invite generation/validation flows
# Keep identical with packages/backend-data/.env(.local).
INVITE_ADMIN_SECRET=replace-with-long-random-secret

# Demo auth (planned): session cookie signing secret
# Keep identical with packages/backend-data/.env(.local).
SESSION_SECRET=replace-with-long-random-secret

# Demo auth (planned): session lifetime in hours
# Keep identical with packages/backend-data/.env(.local).
SESSION_TTL_HOURS=336
