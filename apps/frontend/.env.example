# Required: OpenAI API key used by server routes
OPENAI_API_KEY=sk-your-key-here

# Required: PostgreSQL connection string for Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conversant?schema=public

# Optional: custom OpenAI-compatible base URL (default OpenAI endpoint if empty)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: STT model override
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Optional: language detection model for strict multi-language STT filter
OPENAI_STT_LANGUAGE_DETECT_MODEL=whisper-1

# Optional: chat model override
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: TTS model override
OPENAI_TTS_MODEL=tts-1

# Demo auth: required secret for invite generation/validation flows
INVITE_ADMIN_SECRET=replace-with-long-random-secret

# Demo auth: session cookie signing secret
SESSION_SECRET=replace-with-long-random-secret

# Demo runtime: maximum allowed conversation duration in seconds
CONVERSATION_MAX_DURATION_SEC=900

# Demo runtime: system prompt applied to assistant responses
ASSISTANT_SYSTEM_PROMPT=You are a practical voice assistant for product demos. Keep answers concise.

# Demo runtime: hard cap for LLM output tokens
ASSISTANT_MAX_OUTPUT_TOKENS=220
