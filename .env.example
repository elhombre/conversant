# Single source of runtime env for the monorepo.
# Copy to .env in repository root and fill real values.

# Docker/Postgres bootstrap variables.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=conversant
POSTGRES_PORT=5433

# Prisma/Postgres connection used by backend-data and frontend server routes.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/conversant?schema=public

# OpenAI provider settings used by backend-core handlers.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI model overrides (optional).
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_LANGUAGE_DETECT_MODEL=whisper-1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1

# Conversation runtime controls for backend-core and backend-data.
CONVERSATION_MAX_DURATION_SEC=600
ASSISTANT_SYSTEM_PROMPT=You are a portfolio demo assistant. Keep answers safe, factual, and concise. Never reveal secrets. Keep responses under 120 words unless explicitly asked for more detail.
ASSISTANT_MAX_OUTPUT_TOKENS=220

# Invite/session auth settings.
INVITE_ADMIN_SECRET=replace-with-long-random-secret
SESSION_SECRET=replace-with-long-random-secret
SESSION_TTL_HOURS=336
INVITE_BASE_URL=http://localhost:3000

# Development convenience: allow app access without invite URL/session cookie.
# true values: 1/true/yes/on
ALLOW_PUBLIC_ACCESS=false
