# Runtime scope: packages/backend-data (Prisma CLI commands)
# Required: PostgreSQL connection string for schema generation and migrations
# Keep identical with apps/frontend/.env(.local).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conversant?schema=public

# Required for invite token hashing in generation and consume flows
# Keep identical with apps/frontend/.env(.local).
INVITE_ADMIN_SECRET=replace-with-long-random-secret

# Required for session token hashing in consume/session flows
# Keep identical with apps/frontend/.env(.local).
SESSION_SECRET=replace-with-long-random-secret

# Optional: session lifetime in hours (default: 336)
# Keep identical with apps/frontend/.env(.local).
SESSION_TTL_HOURS=336

# Optional: base URL used by invite generation script output
# Keep identical with apps/frontend/.env(.local) if frontend serves invite consume endpoint.
INVITE_BASE_URL=http://localhost:3000

# Invite generation script reads env only from:
# - code/packages/backend-data/.env(.local)
