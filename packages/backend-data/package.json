{
  "name": "@conversant/backend-data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "biome check",
    "format": "biome format --write",
    "check-types": "yarn prisma:generate && tsc --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "invite:generate": "tsx scripts/generate-invite.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^20",
    "prisma": "6.19.2",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
